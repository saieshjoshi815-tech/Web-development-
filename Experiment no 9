<!DOCTYPE html>
<html>
<head>
    <title>Validated Form</title>
</head>
<body>

<h2>Complete Registration Form</h2>

<form action="submit.php" method="post">

    <!-- Full Name (First Middle Last) -->
    Full Name:
    <input type="text" name="fullname" 
    placeholder="First Middle Last"
    pattern="[A-Za-z]{3,} [A-Za-z]{3,} [A-Za-z]{3,}" 
    title="Enter First Middle Last name (min 3 letters each)" 
    required>
    <br><br>

    <!-- Email -->
    Email:
    <input type="email" name="email" required>
    <br><br>

    <!-- Password -->
    Password:
    <input type="password" name="password" 
    minlength="6" maxlength="12" required>
    <br><br>

    <!-- Age -->
    Age:
    <input type="number" name="age" min="18" max="60" required>
    <br><br>

    <!-- Date -->
    DOB:
    <input type="date" name="dob" required>
    <br><br>

    <!-- Gender -->
    Gender:
    <input type="radio" name="gender" value="male" required> Male
    <input type="radio" name="gender" value="female"> Female
    <br><br>

    <!-- Mobile Number (10 digits) -->
    Mobile:
    <input type="tel" name="phone" 
    pattern="[0-9]{10}" 
    maxlength="10"
    placeholder="10 digit number"
    title="Enter exactly 10 digits"
    required>
    <br><br>

    <!-- Skills (at least one required using required in first checkbox) -->
    Skills:
    <input type="checkbox" name="skill" value="html" required> HTML
    <input type="checkbox" name="skill" value="css"> CSS
    <input type="checkbox" name="skill" value="java"> Java
    <br><br>

    <!-- Department -->
    Department:
    <select name="dept" required>
        <option value="">Select</option>
        <option>HR</option>
        <option>IT</option>
        <option>Finance</option>
    </select>
    <br><br>

    <!-- Address -->
    Address:
    <textarea name="address" rows="4" cols="30" required></textarea>
    <br><br>

    <!-- File Upload -->
    Upload Resume:
    <input type="file" name="file" accept=".pdf,.doc,.docx" required>
    <br><br>

    <!-- Website -->
    Website:
    <input type="url" name="website" placeholder="https://example.com">
    <br><br>

    <!-- Experience -->
    Experience (0-10):
    <input type="range" name="exp" min="0" max="10">
    <br><br>

    <!-- Country -->
    Country:
    <input type="text" value="India" readonly>
    <br><br>

    <!-- Hidden -->
    <input type="hidden" name="userid" value="101">

    <!-- Buttons -->
    <input type="submit" value="Submit">
    <input type="reset" value="Reset">

</form>

</body>
</html>
