<!DOCTYPE html>
<html>
<head>
    <title>Table Example</title>
</head>
<body>

<h2>Student Table</h2>

<table border="1">
    <tr>
        <th>Name</th>
        <th>Age</th>
        <th>City</th>
    </tr>

    <tr>
        <td>Sid</td>
        <td>20</td>
        <td>Pune</td>
    </tr>

    <tr>
        <td>Rahul</td>
        <td>21</td>
        <td>Mumbai</td>
    </tr>

    <tr>
        <td>Priya</td>
        <td>19</td>
        <td>Kolhapur</td>
    </tr>

</table>

</body>
</html>
